{
  "name": "backend-sistem-booking-ruangan-fasilitas",
  "version": "1.2.0",
  "description": "Aplikasi web untuk mengelola peminjaman ruangan dan fasilitas seperti laboratorium, ruang rapat, dan proyektor agar tidak terjadi bentrok jadwal. Pengguna dapat mengecek ketersediaan dan mengajukan booking, lalu setiap pengajuan akan melalui proses approval admin sebelum dinyatakan valid dan dapat digunakan.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles"
  },
  "repository": {
    "type": "git",
